--Question 1: Basic SELECT, Write an SQL query to display all columns from the sales table.​

SELECT *
FROM sales_data_set_1;

--Question 2: Selecting Specific Columns​, Write an SQL query to display the following columns from the sales table:​Store​,Dept​, Weekly_Sales

SELECT Store, Dept, Weekly_Sales
FROM sales_data_set_1;

--Question 3: Using WHERE​, Write an SQL query to display all records from the sales table where:​ Store = 1

SELECT*
FROM sales_data_set_1
WHERE Store =1;

--Question 4: Using Comparison Operators​, Write an SQL query to display all records where:​ Weekly_Sales is greater than 20,000​, Sort the results from highest to lowest Weekly_Sales.

SELECT *
FROM sales_data_set_1
WHERE Weekly_Sales > 20000
ORDER BY Weekly_Sales DESC;

--Question 5: Using BETWEEN (Dates)​, Write an SQL query to show all sales that occurred between 01/03/2010 and 31/03/2010.​ Display:​Store​, Dept​, Date​, Weekly_Sales

SELECT Store,Dept,Date,Weekly_Sales
FROM sales_data_set_1
WHERE Date BETWEEN '2010-03-01' AND '2010-03-31';

--Question 6: Working with lists, Write an SQL query to show all records from the sales table where:​ Store is 1, 3, or 5

SELECT *
FROM sales_data_set_1
WHERE Store =1 OR Store = 3 OR Store = 5;

SELECT *
FROM sales_data_set_1
WHERE Store IN (1,3,5);

--Question 7: Aggregation, Write an SQL query to calculate the total Weekly_Sales for the entire dataset.

SELECT SUM (Weekly_Sales) AS Total_Weekly_Sales
FROM sales_data_set_1;

--Question 8: Summing Data:
--Write an SQL query to show the total Weekly_Sales for each Store.​
--Display:​ Store​, Total Sales​
--Sort results from highest sales to lowest sales.

SELECT Store, SUM(Weekly_Sales) AS Total_Sales
FROM sales_data_set_1
GROUP BY Store
ORDER BY Total_Sales DESC;

--Question 9​: 
--Write an SQL query to display stores where total Weekly_Sales is greater than 1,000,000.​
--Display:​ Store​, Total Weekly Sale

SELECT Store, SUM(Weekly_Sales) AS Total_Weekly_Sales
FROM sales_data_set_1
GROUP BY Store
HAVING Total_Weekly_Sales > 1000000; 

--Question 10​:Using the sales and stores tables:​
--Write an SQL query to display:​ Store​, Type​, Weekly_Sales​
-- Use an INNER JOIN between the tables.

-- Dataset Check > sales_data_set_1
SELECT *
FROM sales_data_set_1
LIMIT 5;
--Store, Dept, Date(YYYY_MM_DD), Weekly_Sales, IsHoliday(True/False)

-- Dataset Check > stores_data_set_1
SELECT *
FROM stores_data_set_1
LIMIT 5;
--Store, Type, Size

-- My notes: 
--Both tables have a Store column that can be used for joining.
-- sales_data_set_1 is fact table (numberical)
-- stores_data_set_1 is dimension table(descriptive)

SELECT sales_data_set_1.Store, stores_data_set_1.Type, sales_data_set_1.Weekly_Sales
FROM sales_data_set_1
INNER JOIN stores_data_set_1
ON sales_data_set_1.Store = stores_data_set_1.Store; 





-- Challenge: Using the sales, stores, and features tables, Write an SQL query to find:​
-- Top 5 stores with the highest total Weekly Sales during holiday weeks
--Including the store type and the average temperature during those sales weeks.​

--Requirements:​
--Only include records where IsHoliday = TRUE​
--Calculate total Weekly Sales per store​
--Calculate average temperature per store​

--Your output should include:​ Store​, Store_Type​, Total_Weekly_Sales​, Average Temperature

-- Dataset Check > sales_data_set_1
SELECT *
FROM sales_data_set_1
LIMIT 5;
--Store, Dept, Date(YYYY_MM_DD), Weekly_Sales, IsHoliday(True/False)

-- Dataset Check > stores_data_set_1
SELECT *
FROM stores_data_set_1
LIMIT 5;
--Store, Type, Size

-- Dataset Check > features_data_set_in_1
SELECT *
FROM features_data_set_in_1
LIMIT 5;
--Store, Date(YYYY_MM_DD), Temperature,Fuel_Price, CPI, Unemployment, IsHoliday(True/False)

-- My notes: 
--All three tables have a Store column.
-- sales_data_set_1 is fact table (numberical)
-- stores_data_set_1 is dimension table(descriptive)
-- features_data_set_in_1 gives insights on sales_data_set_1


SELECT sales_data_set_1.Store, stores_data_set_1.Type AS Store_Type,SUM(sales_data_set_1.Weekly_Sales) AS Total_Weekly_Sales,AVG(features_data_set_in_1.Temperature) AS Average_Temperature
FROM sales_data_set_1
INNER JOIN stores_data_set_1
ON sales_data_set_1.Store = stores_data_set_1.Store
INNER JOIN features_data_set_in_1
ON sales_data_set_1.Store = features_data_set_in_1.Store AND sales_data_set_1.Date = features_data_set_in_1.Date
WHERE sales_data_set_1.IsHoliday = TRUE
GROUP BY sales_data_set_1.Store, Store_Type
ORDER BY Total_Weekly_Sales DESC
LIMIT 5;

--Challenge​: 
--Join all relevant tables​
--Sort results from highest to lowest Total Weekly Sales​
--Return only the top 5 stores

SELECT sales_data_set_1.Store, SUM(sales_data_set_1.Weekly_Sales) AS Total_Weekly_Sales
FROM sales_data_set_1
INNER JOIN stores_data_set_1
ON sales_data_set_1.Store = stores_data_set_1.Store
GROUP BY sales_data_set_1.Store
ORDER BY Total_Weekly_Sales DESC
LIMIT 5;